nstallation\n\nThis module is installed via npm:\n\n``` bash\n$ npm install git-config\n```\n\n## Example Usage\n\n### Asynchronous\n\n``` js\nvar gitConfig = require('git-config');\ngitConfig(function (err, config) {\n  if (err) return done(err);\n  expect(config.user.name).to.equal('Eugene Ware');\n  expect(config.user.email).to.equal('eugene@noblesamurai.com');\n  expect(config.github.user).to.equal('eugeneware');\n  done();\n});\n```\n\nExplicitly give a gitconfig file:\n\n``` js\nvar gitConfig = require('git-config');\ngitConfig('/my/path/.gitconfig1', function (err, config) {\n  if (err) return done(err);\n  expect(config.user.name).to.equal('Eugene Ware');\n  expect(config.user.email).to.equal('eugene@noblesamurai.com');\n  expect(config.github.user).to.equal('eugeneware');\n  done();\n});\n```\n\n### Synchronous\n\n``` js\nvar gitConfig = require('git-config');\nvar config = gitConfig.sync(); // can pass explit file if you want as well\n```\n","maintainers":[{"name":"eugeneware","email":"eugene@noblesamurai.com"}],"time":{"modified":"2022-06-18T08:27:09.747Z","created":"2013-09-11T13:28:00.101Z","0.0.1":"2013-09-11T13:28:04.705Z","0.0.2":"2013-09-11T13:35:56.276Z","0.0.3":"2013-09-11T14:51:53.821Z","0.0.4":"2014-02-25T23:49:36.475Z","0.0.5":"2014-02-26T01:27:29.534Z","0.0.6":"2014-02-26T01:31:44.574Z","0.0.7":"2015-06-13T05:26:38.111Z"},"author":{"name":"Eugene Ware","email":"eugene@noblesamurai.com"},"repository":{"type":"git","url":"https://github.com/eugeneware/git-config"},"homepage":"https://github.com/eugeneware/git-config","keywords":[],"bugs":{"url":"https://github.com/eugeneware/git-config/issues"},"license":"BSD-3-Clause","readmeFilename":"README.md"}